---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/rochses-logo.png';

const mediaSlots = [
	{ label: '01 — Campaign', src: '/campaign.jpg', span: 'md:col-span-7 md:row-span-2 aspect-[4/5]' },
	{ label: '02 — Detail', src: '/detail.jpg', span: 'md:col-span-5 aspect-[4/3]', rotate: true },
	{ label: '03 — Archive', src: '/archive.jpg', span: 'md:col-span-5 aspect-[4/3]' },
	{ label: '04 — Studio', src: '/studio.jpg', span: 'md:col-span-6 aspect-[16/10]' },
	{ label: '05 — Collage', src: '/collage.jpg', span: 'md:col-span-6 aspect-[16/10]' },
];
---

<Layout>
	<div class="flex min-h-screen flex-col">
		<header class="flex flex-col items-center gap-6 px-6 pt-20 pb-16 sm:gap-8 sm:pt-24 sm:pb-20 md:gap-10 md:pt-28 md:pb-24">
			<Image
				src={logo}
				alt="Rochses"
				width={1330}
				height={638}
				class="h-auto w-full max-w-[140px] grayscale sm:max-w-[170px] md:max-w-[200px]"
				priority
			/>

			<p class="text-center font-sans font-light uppercase text-ink text-sm tracking-[0.5em] sm:text-base sm:tracking-[0.6em] md:text-lg">
				Coming Soon
			</p>

			<a
				href="https://forms.gle/NZHosZSNxHFEhZ469"
				target="_blank"
				rel="noopener noreferrer"
				class="-my-3 -mx-2 inline-block px-2 py-3 font-serif italic text-ink-soft text-sm tracking-[0.08em] underline decoration-line decoration-1 underline-offset-4 transition-colors hover:text-ink hover:decoration-ink sm:text-base"
			>
				help shape the first collection
			</a>
		</header>

		<main class="flex-1">
			<section aria-label="Campaign imagery" class="mx-auto max-w-5xl px-6 pb-32 sm:pb-44">
				<div class="grid grid-cols-1 gap-4 md:grid-cols-12">
					{mediaSlots.map((slot) => (
						<div class={`relative w-full overflow-hidden border border-line ${slot.span}`}>
							<img
								src={slot.src}
								alt={slot.label}
								loading="lazy"
								class={`h-full w-full object-cover ${slot.rotate ? 'rotate-90 scale-[1.3334]' : ''}`}
							/>
						</div>
					))}
				</div>
			</section>

			<section class="border-t border-line px-6 py-20 sm:py-28">
				<div class="mx-auto max-w-md text-center">
					<h2 class="font-serif text-2xl uppercase tracking-[0.15em] text-ink sm:text-3xl">
						Secure Priority Access
					</h2>

					<form class="mt-10 flex flex-col gap-6 sm:flex-row sm:items-end sm:gap-4" action="#" method="post">
						<label for="email" class="sr-only">Email address</label>
						<input
							id="email"
							name="email"
							type="email"
							required
							placeholder="Your email address"
							class="w-full border-0 border-b border-line bg-transparent px-1 py-3 text-sm text-ink placeholder:text-ink-soft/70 focus:border-ink focus:outline-none"
						/>
						<button
							type="submit"
							class="group relative whitespace-nowrap px-1 py-3 text-xs font-medium uppercase tracking-[0.3em] text-ink"
						>
							Register
							<span class="absolute inset-x-0 bottom-2 h-px w-full origin-left scale-x-100 bg-ink transition-transform group-hover:scale-x-0"></span>
						</button>
					</form>
				</div>
			</section>
		</main>

		<footer class="border-t border-line px-6 py-8">
			<p class="text-center text-[0.65rem] uppercase tracking-[0.35em] text-ink-soft">
				Rochses &copy; {new Date().getFullYear()}
			</p>
		</footer>
	</div>
</Layout>
